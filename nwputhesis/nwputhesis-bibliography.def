%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

%% 参考文献及附录处理
%%-----------------------------------------------------------------------------%
\setlength{\biblabelsep}{0pt}                              %
\newlength{\nwpu@bibfirstlineindent}                       %
\AtBeginDocument{\settowidth{\nwpu@bibfirstlineindent}{汉汉}} %
\newlength{\nwpu@biblabelwidth}                            %
\newlength{\nwpu@bibfirstlinereserve}                      %
\setlength{\nwpu@bibfirstlinereserve}{1.5em}               %
\ExplSyntaxOn
\tl_new:N \l__nwpu_patent_number_tl
\cs_new_protected:Npn \nwpu_patent_number_allowbreaks:n #1
  {
    \tl_set:Nn \l__nwpu_patent_number_tl {#1}
    \regex_replace_all:nnN {([A-Za-z])([0-9])} {\1\c{allowbreak}\2} \l__nwpu_patent_number_tl
    \regex_replace_all:nnN {([0-9])([A-Za-z])} {\1\c{allowbreak}\2} \l__nwpu_patent_number_tl
    \tl_use:N \l__nwpu_patent_number_tl
  }
\cs_new_protected:Npn \nwpuPatentNumberAllowBreaks #1
  {
    \nwpu_patent_number_allowbreaks:n {#1}
  }
\ExplSyntaxOff
\DeclareFieldFormat[patent]{title}{#1}
\DeclareFieldFormat[patent]{number}{\nwpuPatentNumberAllowBreaks{#1}}
\renewbibmacro*{title}{%
\ifboolexpr{%
    test{\iffieldundef{title}}%
    and
    test{\iffieldundef{subtitle}}}%
    {}%
    {\printtext[title]{\bibtitlefont%
       \iffieldequalstr{entrysubtype}{standard}{%
            \iffieldundef{number}{}{\printtext{\thefield{number}}\setunit{\addcomma\space}}%
       }{}%
       \printfield[titlecase]{title}%
       \ifboolexpr{test {\iffieldundef{subtitle}}}%
            {}{\setunit{\subtitlepunct}\printfield[titlecase]{subtitle}}%
       \iffieldundef{titleaddon}{}{\setunit{\subtitlepunct}\printfield{titleaddon}}%
       \ifboolexpr{test{\ifentrytype{book}} and (not test{\iffieldundef{volume}})}%
            {\setunit{\subtitlepunct}\printfield{volume}}{}%
       \ifboolexpr{(test{\ifentrytype{archive}} or  test{\ifentrytype{online}}) and (not test{\iffieldundef{number}})}%
            {\setunit{\subtitlepunct}\printfield{number}}{}%
       \iftoggle{bbx:gbtype}%
            {\iffieldundef{entrysubtype}{\printfield[gbtypeflag]{usera}}%
            {\iffieldequalstr{entrysubtype}{standard}{\printfield[gbtypeflags]{usera}}%
                  {\iffieldequalstr{entrysubtype}{news}{\printfield[gbtypeflagn]{usera}}%
                  {\printfield[gbtypeflag]{usera}}}}}{}%
       }%
    }%
}
\DeclareBibliographyDriver{patent}{%
    \usebibmacro{bibindex}%
    \usebibmacro{begentry}%
    \usebibmacro{author/translator+others}%
    \ifnameundef{author}{}{\setunit{\labelnamepunct}\newblock}%
    \printtext[title]{\bibtitlefont\printfield[titlecase]{title}}%
    \mbox{[P]}%
    \newunit\newblock%
    \printlist{location}%
    \iffieldundef{number}{}{%
        \setunit{\addcolon\addspace}%
        \printfield{number}%
    }%
    \ifboolexpr{
        not test {\iffieldundef{year}}
        or
        not test {\iffieldundef{month}}
        or
        not test {\iffieldundef{day}}
    }{%
        \setunit{\addcomma\addspace}%
        \usebibmacro{newsdate}%
    }{}%
    \usebibmacro{finentry}%
}
\newbibmacro*{nwpu:miscfullinstitution+location+date}{%
  \bibpubfont%
  \iflistundef{institution}
    {}
    {\printlist{institution}\setunit*{\adddot\space}}%
  {\printlist{location}%
   \iflistundef{location}
     {}
     {\iflistundef{institution}
        {\setunit*{\adddot\space}}
        {\setunit*{\addcolon\space}}}%
   \ifboolexpr{
        not test {\iffieldundef{year}}
        or
        not test {\iffieldundef{month}}
        or
        not test {\iffieldundef{day}}
   }
     {\usebibmacro{newsdate}}
     {}}}
\DeclareBibliographyDriver{misc}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \usebibmacro{author/editor+others/translator+others}%
  \ifnameundef{namea}{}{\setunit{\labelnamepunct}\newblock}%
  \usebibmacro{title}%
  \iftoggle{bbx:gbstrict}{}{%
    \newunit
    \printlist{language}%
    \newunit\newblock
    \usebibmacro{byauthor}%
    \newunit\newblock
    \usebibmacro{byeditor+others}}%
  \newunit\newblock
  \printfield{howpublished}%
  \newunit\newblock
  \printfield{type}%
  \newunit
  \printfield{version}%
  \newunit
  \printfield{note}%
  \newunit\newblock
  \usebibmacro{nwpu:miscfullinstitution+location+date}%
  \usebibmacro{chapter+pages}%
  \usebibmacro{doi+eprint+url}%
  \newunit\newblock
  \usebibmacro{addendum+pubstate}%
  \setunit{\bibpagerefpunct}\newblock
  \usebibmacro{pageref}%
  \newunit\newblock
  \iftoggle{bbx:related}
    {\usebibmacro{related:init}\usebibmacro{related}}
    {}%
  \usebibmacro{annotation}\usebibmacro{finentry}}
\DeclareBibliographyDriver{other}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \usebibmacro{author/editor+others/translator+others}%
  \ifnameundef{namea}{}{\setunit{\labelnamepunct}\newblock}%
  \usebibmacro{title}%
  \iftoggle{bbx:gbstrict}{}{%
    \newunit
    \printlist{language}%
    \newunit\newblock
    \usebibmacro{byauthor}%
    \newunit\newblock
    \usebibmacro{byeditor+others}}%
  \newunit\newblock
  \printfield{howpublished}%
  \newunit\newblock
  \printfield{type}%
  \newunit
  \printfield{version}%
  \newunit
  \printfield{note}%
  \newunit\newblock
  \ifboolexpr{
      not test {\iffieldundef{year}}
      or
      not test {\iffieldundef{month}}
      or
      not test {\iffieldundef{day}}
  }{\usebibmacro{newsdate}}{}%
  \usebibmacro{chapter+pages}%
  \usebibmacro{doi+eprint+url}%
  \newunit\newblock
  \usebibmacro{addendum+pubstate}%
  \setunit{\bibpagerefpunct}\newblock
  \usebibmacro{pageref}%
  \newunit\newblock
  \iftoggle{bbx:related}
    {\usebibmacro{related:init}\usebibmacro{related}}
    {}%
  \usebibmacro{annotation}\usebibmacro{finentry}}
\ifbachelor{%
    \DeclareStyleSourcemap{
        \maps[datatype=bibtex]{
            \map[overwrite]{
                \pertype{conference}
                \step[fieldset=usera, fieldvalue={A}]
            }
            \map[overwrite]{
                \pertype{inproceedings}
                \step[fieldset=usera, fieldvalue={A}]
            }
        }
    }
    \DeclareDriverSourcemap[datatype=bibtex]{
        \map{
            \step[typesource=conference, typetarget=nwpubachelorconf]
        }
        \map{
            \step[typesource=inproceedings, typetarget=nwpubachelorconf]
        }
    }
    \DeclareFieldFormat[nwpubachelorconf]{title}{#1}
    \DeclareFieldFormat[nwpubachelorconf]{booktitle}{#1}
    \newbibmacro*{nwpu:bachelorbooktitle}{%
        \ifboolexpr{
            test {\iffieldundef{booktitle}}
            and
            test {\iffieldundef{booksubtitle}}
        }
            {}
            {\printtext[booktitle]{\bibtitlefont%
                \printfield[booktitlecase]{booktitle}%
                \iffieldundef{booksubtitle}{}{\setunit{\subtitlepunct}\printfield[booktitlecase]{booksubtitle}}%
                \printtext{[C]}%
            }}%
    }
    \newbibmacro*{nwpu:bachelorin}{%
        \setunit{\adddot\addspace}%
        \iffieldequalstr{userd}{chinese}
            {\printtext{\bibstring{incn}}}
            {\printtext{\bibstring{in}}}%
    }
    \DeclareBibliographyDriver{nwpubachelorconf}{%
        \usebibmacro{bibindex}%
        \usebibmacro{begentry}%
        \usebibmacro{author/translator+others}%
        \ifnameundef{author}{}{\setunit{\labelnamepunct}\newblock}%
        \usebibmacro{title}%
        \usebibmacro{nwpu:bachelorin}%
        \usebibmacro{bybookauthor}%
        \ifnameundef{bookauthor}{%
            \ifnameundef{editor}{}{\newunit}%
        }{\newunit}%
        \iffieldundef{series}{}{\usebibmacro{series+number}\setunit{\addcolon\addspace}}%
        \usebibmacro{nwpu:bachelorbooktitle}%
        \iffieldundef{volume}{}{\setunit{\addcolon\addspace}\printfield{volume}}%
        \iffieldundef{number}{}{\setunit{\addcolon\addspace}\printfield{number}}%
        \newunit\newblock%
        \printfield{edition}%
        \newunit\newblock%
        \usebibmacro{publisher+location+date}%
        \usebibmacro{chapter+pages}%
        \usebibmacro{doi+eprint+url}%
        \newunit\newblock%
        \iftoggle{bbx:isbn}
            {\printfield{isbn}}
            {}%
        \newunit\newblock%
        \usebibmacro{addendum+pubstate}%
        \setunit{\bibpagerefpunct}\newblock%
        \usebibmacro{pageref}%
        \newunit\newblock%
        \iftoggle{bbx:related}
            {\usebibmacro{related:init}\usebibmacro{related}}
            {}%
        \usebibmacro{annotation}\usebibmacro{finentry}%
    }
}{}
\newcommand{\nwpu@bibitemcmd}{%
    \addvspace{\bibitemsep}%
    \leavevmode%
    \if@npu@type@bcl
        \hspace*{0pt}%
    \else
        \hspace*{\nwpu@bibfirstlineindent}%
    \fi
    \mkgbnumlabel{\printfield{labelnumber}}\hspace{0.3em}}
\defbibenvironment{bibliography}
    {\begingroup\setlength{\parindent}{0pt}\setlength{\emergencystretch}{2em}\sloppy}
    {\endgroup}
    {\nwpu@bibitemcmd}
\AtBeginBibliography{                                        %
    \graduatebodyfont                                       %
    \setlength{\bibitemsep}{0.5ex}                          %
    \setlength{\bibhang}{0pt}                               %
}                                                           %
\let\nwpu@oldprintbibliography\printbibliography            %
\RenewDocumentCommand{\printbibliography}{O{}}{             %
    \cleardoublepage                                        %
    \nwpu@oldprintbibliography[                             %
        heading=bibintoc,                                   %
        title={参考文献},                                     %
        #1                                                  %
    ]                                                       %
    \cleardoublepage                                        %
}                                                           %
%%-----------------------------------------------------------------------------%
\patchcmd{\hyper@makecurrent}{%                             % 附录章节引用补丁
    \ifx\Hy@param\Hy@chapterstring                          %
        \let\Hy@param\Hy@chapapp\fi}{\iftoggle{inappendix}{%% 修复附录中章节引用
        \@checkappendixparam{chapter}%                      %
        \@checkappendixparam{section}%                      %
        \@checkappendixparam{subsection}%                   %
        \@checkappendixparam{subsubsection}%                %
        \@checkappendixparam{paragraph}%                    %
        \@checkappendixparam{subparagraph}%                 %
    }{}}{}{\errmessage{failed to patch}}                    %
\newcommand*{\@checkappendixparam}[1]{%                     %
    \def\@checkappendixparamtmp{#1}%                        %
    \ifx\Hy@param\@checkappendixparamtmp                    %
        \let\Hy@param\Hy@appendixstring                     %
    \fi}                                                    %
\newtoggle{inappendix}\togglefalse{inappendix}              %
\apptocmd{\appendix}{\toggletrue{inappendix}}{}{\errmessage{failed to patch}}
\apptocmd{\subappendices}{\toggletrue{inappendix}}{}{\errmessage{failed to patch}}
\appto\appendix{\addtocontents{toc}{\protect\setcounter{tocdepth}{0}}}
\appto\listoffigures{\addtocontents{lof}{\protect\setcounter{tocdepth}{1}}}
\appto\listoftables{\addtocontents{lot}{\protect\setcounter{tocdepth}{1}}}
%%-----------------------------------------------------------------------------%
\newif\ifnwpu@thesisappendixmode
\nwpu@thesisappendixmodefalse
\newcounter{nwpu@thesisappendixcount}
\newcounter{nwpu@thesisappendixtotal}
\setcounter{nwpu@thesisappendixtotal}{1}
\newcommand{\nwpu@setappendixtotal}[1]{%
    \setcounter{nwpu@thesisappendixtotal}{#1}%
}
\newcommand{\nwpuSetAppendixTotal}[1]{%
    \nwpu@setappendixtotal{#1}%
}
\newcommand{\nwpu@chs@appendixname}[1]{附录 #1}             % 目录附录中文标题
\newcommand{\nwpu@eng@appendixname}[1]{Appendix #1}         % 目录附录英文标题
\newcommand{\nwpu@appendixname}[1]{%                        % 附录标题
    \if@npu@lang@chs
        \nwpu@chs@appendixname{#1}%
    \else
        \nwpu@eng@appendixname{#1}%
    \fi
}
\newcommand{\nwpu@ifappendixletter}[2]{%                    % 附录是否显示字母
    \if@npu@type@bcl
        \ifnum\value{nwpu@thesisappendixtotal}>1
            #1%
        \else
            #2%
        \fi
    \else
        #1%
    \fi
}
\newcommand{\nwpu@appendixtitle}[1]{%                       % 附录显示标题
    \nwpu@ifappendixletter{\nwpu@appendixname{#1}}{\nwpu@page@app}%
}
\newcommand{\nwpu@appendixprefix}{%                        % 附录编号前缀
    \nwpu@ifappendixletter{\Alph{chapter}}{}%
}
\newcommand{\nwpu@appendixequationprefix}{%                % 附录公式编号前缀
    \if@npu@type@bcl
        附%
    \else
        \nwpu@ifappendixletter{\nwpu@appendixprefix-}{}%
    \fi
}
\newcommand{\nwpu@appendixtableprefix}{%                   % 附录表编号前缀
    \if@npu@type@bcl
        附%
    \else
        \nwpu@ifappendixletter{\nwpu@appendixprefix-}{}%
    \fi
}
\newcommand{\nwpu@appendixfigureprefix}{%                  % 附录图编号前缀
    \if@npu@type@bcl
        附%
    \else
        \nwpu@ifappendixletter{\nwpu@appendixprefix-}{}%
    \fi
}
\newcommand{\nwpu@appendixalgorithmprefix}{%               % 附录算法编号前缀
    \if@npu@type@bcl
        附%
    \else
        \nwpu@ifappendixletter{\nwpu@appendixprefix-}{}%
    \fi
}
\AtEndDocument{%
    \protected@write\@auxout{}{%
        \string\nwpuSetAppendixTotal{\arabic{nwpu@thesisappendixcount}}%
    }%
}
\let\old@appendix\appendix                                  % 保护原有附录环境
\renewcommand{\appendix}{                                   % 在原有基础上定制
    \old@appendix                                           %
    \setcounter{chapter}{0}                                 % 重置章节编号
    \renewcommand{\thechapter}{\Alph{chapter}}              %
    \renewcommand{\thesection}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{section}}
    \renewcommand{\theequation}{%
        \nwpu@appendixequationprefix\arabic{equation}}
    \renewcommand{\thetable}{%
        \nwpu@appendixtableprefix\arabic{table}}%
    \renewcommand{\thefigure}{%
        \nwpu@appendixfigureprefix\arabic{figure}}
    \renewcommand{\thealgorithm}{%
        \nwpu@appendixalgorithmprefix\arabic{algorithm}}
    \renewcommand{\thetheorem}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{theorem}}
    \renewcommand{\theaxiom}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{axiom}}%
    \renewcommand{\thecorollary}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{corollary}}
    \renewcommand{\thelemma}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{lemma}}%
    \renewcommand{\thedefinition}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{definition}}
    \renewcommand{\theexample}{%
        \nwpu@ifappendixletter{\nwpu@appendixprefix.}{}\arabic{example}}
}                                                           %
